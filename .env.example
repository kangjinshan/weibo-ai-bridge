# ============================================
# weibo-ai-bridge 环境变量配置文件
# 复制此文件为 .env 并填入实际配置
# ============================================

# 服务器配置
SERVER_PORT=5533
SERVER_HOST=0.0.0.0
SERVER_MODE=debug

# 微博平台配置（必填）
WEIBO_APP_ID=your-app-id
WEIBO_APP_Secret=your-app-Secret
WEIBO_TOKEN_URL=http://open-im.api.weibo.com/open/auth/ws_token
WEIBO_WS_URL=ws://open-im.api.weibo.com/ws/stream
WEIBO_TIMEOUT=30

# Claude Agent 配置
# Claude API Key 和模型配置请在 Claude Code 配置中设置
# 参考配置位置：~/.config/claude/config.json
# 或通过环境变量设置：export ANTHROPIC_API_KEY="sk-ant-xxxxx"
CLAUDE_ENABLED=true

# CodeX Agent 配置
CODEX_API_KEY=your-codex-api-key
# 留空则沿用本机 codex CLI 默认 provider/model 配置
CODEX_MODEL=
CODEX_ENABLED=false

# 如果 codex CLI 使用 Azure OpenAI provider，请同时提供以下环境变量
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=your-azure-openai-deployment
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/responses

# 会话配置
SESSION_TIMEOUT=3600
SESSION_MAX_SIZE=1000

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
